# Directorio base donde lablog guarda eventos, bóveda y figuras.
# Por defecto: ~/.lablog
# Para versionar tus notas en el repo y publicarlas en GitHub Pages, usa:
# LABLOG_DATA_DIR=./data
LABLOG_DATA_DIR=~/.lablog

# Host y puerto del servidor API.
LABLOG_HOST=127.0.0.1
LABLOG_PORT=8000

# Orígenes permitidos por CORS. Separa con comas.
LABLOG_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Permitir cookies/credenciales en peticiones CORS.
LABLOG_CORS_CREDENTIALS=true

# Directorio de salida para el sitio estático exportado.
# LABLOG_SITE_DIR=./site
